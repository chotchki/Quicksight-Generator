# mapping.yaml — SNB source string → real-program string
#
# PRIVATE TEMPLATE. This file is not published.
#
# The authoritative mapping is hand-maintained on the GitLab-wiki side
# (never in this repo) so that real-program names never enter source
# control here. This file is a *template* and *checklist*: it enumerates
# the SNB strings that appear in handbook/ and need substitution. Values
# are intentionally blank.
#
# To use: copy the structure to your wiki-side mapping file, fill in the
# real-program values there, and feed that file (not this one) to the
# publish script.
#
# See translation-notes.md at the repo root for the rationale behind
# each mapping.

# --- Institution identity ---
institution:
  "Sasquatch National Bank": ""
  "SNB": ""

# --- Stakeholders / counterparties mentioned in handbook text ---
stakeholders:
  "Federal Reserve Bank": ""
  "Fed": ""
  "Payment Gateway Processor": ""

# --- GL account codes appearing in concept pages and scenarios ---
# Format in source: `gl-XXXX`. Decide on the wiki side whether these
# become real account numbers, friendly names, or a mix.
gl_accounts:
  "gl-1010": ""    # Cash & Due From FRB → (e.g., Open Loop Funds Pool)
  "gl-1810": ""    # ACH Origination Settlement → (e.g., Sweep Account for ACH)
  "gl-1815": ""    # Card Acquiring Settlement
  "gl-1830": ""    # Internal Transfer Suspense → (e.g., Open Loop Escrow)
  "gl-1850": ""    # Cash Concentration Master (no real analogue)

# --- Named account labels used in scenarios ---
account_labels:
  "Cash & Due From FRB": ""
  "ACH Origination Settlement": ""
  "Card Acquiring Settlement": ""
  "Internal Transfer Suspense": ""
  "Cash Concentration Master": ""

# --- Merchants that appear in scenarios 1 and 2 ---
# Replace with real-program merchant names, or with merchant *types*
# (e.g., "Type A high-volume merchant") if the real roster rotates.
merchants:
  "Big Meadow Dairy": ""
  "Bigfoot Brews": ""
  "Cascade Timber Mill": ""
  "Pinecrest Vineyards LLC": ""
  "Harvest Moon Bakery": ""

# --- Demo-only flavor to strip (replace with empty string or neutral) ---
flavor:
  "Margaret Hollowcreek": ""
  "Pacific Northwest": ""
  "Farmers Exchange Bank": ""

# --- Intentional non-mappings ---
# Industry-standard vocabulary stays as-is. Do not substitute:
#   double-entry, open loop, closed loop, sweep, net-settle,
#   escrow, vouchering, aging bucket, drift, suspense, DDA, ZBA.
# These terms are the same on both sides and are load-bearing for
# the training.
